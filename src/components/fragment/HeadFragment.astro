---
import { FAVICON, SITE_INFO } from '@/config'
import unoThemeVars from '@/styles/uno-theme-vars'

interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  publishDate?: string
  updatedDate?: string
  author?: string
}
const { title, description, image, type = 'website', publishDate, updatedDate, author = SITE_INFO.author } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImage = image && image.startsWith('http')
  ? image
  : image && image.startsWith('/')
  ? new URL(image, Astro.site).href
  : (FAVICON || new URL('/favicon.svg', Astro.site).href)

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_INFO.title,
  url: Astro.site,
}

const articleSchema = type === 'article' && publishDate ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Person', name: author },
  datePublished: publishDate,
  dateModified: updatedDate || publishDate,
  url: canonicalURL,
  image: ogImage,
} : null
---

<!-- Theme -->
<script is:inline>document.documentElement.className = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')</script>
<!-- Uno Theme Vars -->
<style set:html={unoThemeVars}></style>
<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href={FAVICON} rel="preload"/>
<meta name="generator" content={Astro.generator} />
<meta name="referrer" content="no-referrer"/>
<script is:inline type="application/ld+json" set:html={JSON.stringify(siteSchema)}></script>
{articleSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>}
<link rel="alternate" type="application/rss+xml" title={title} href={new URL("rss.xml", Astro.site)}/>
<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
{type === 'article' && publishDate && <meta property="article:published_time" content={publishDate} />}
{type === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate} />}
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />
<!-- SiteMap -->
<link rel="sitemap" href="/sitemap-index.xml" />
<!-- Robots -->
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />